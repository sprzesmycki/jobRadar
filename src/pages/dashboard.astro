---
import Layout from "@/layouts/Layout.astro";
import { getCvProfile } from "@/lib/cv-profile";
import { getJobScores, type JobScore } from "@/lib/job-scores";
import { getMatchedJobs } from "@/lib/jobs";
import { getJobPreferences, joinList } from "@/lib/preferences";
import { getSavedJobs } from "@/lib/saved-jobs";
import { createClient } from "@/lib/supabase";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);

if (!user || !supabase) {
  throw new Error("Dashboard requires an authenticated Supabase session.");
}

const saved = Astro.url.searchParams.get("saved");
const routeError = Astro.url.searchParams.get("error");
const { preferences, errorMessage: preferencesError } = await getJobPreferences(supabase, user.id);
const { savedJobs, errorMessage: savedJobsError } = await getSavedJobs(supabase, user.id);
const { profile: cvProfile, errorMessage: cvProfileError } = await getCvProfile(supabase, user.id);
const pageError = routeError ?? preferencesError ?? savedJobsError ?? cvProfileError;
const {
  jobs,
  message: jobsMessage,
  source: jobsSource,
  warnings: jobSourceWarnings,
  successfulSources,
} = await getMatchedJobs(preferences);
const cachedScores: Map<string, JobScore> =
  jobsSource === "fallback" || !cvProfile
    ? new Map<string, JobScore>()
    : await getJobScores(
        supabase,
        user.id,
        jobs.map((j) => j.id),
      );
const hasPreferences = Boolean(preferences);
const statusLabels = {
  interested: "Interested",
  applied: "Applied",
  rejected: "Rejected",
};
const currencyOptions = ["EUR", "USD", "PLN"];

function formatBytes(bytes: number): string {
  if (bytes < 1024 * 1024) {
    return `${Math.max(1, Math.round(bytes / 1024))} KB`;
  }

  return `${(bytes / 1024 / 1024).toFixed(1)} MB`;
}
---

<Layout title="JobRadar Dashboard">
  <main class="min-h-screen bg-slate-950 text-slate-100">
    <header class="border-b border-slate-800 bg-slate-950/95">
      <div
        class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-5 sm:flex-row sm:items-center sm:justify-between sm:px-6"
      >
        <div>
          <p class="text-sm font-medium text-cyan-300">JobRadar</p>
          <h1 class="text-2xl font-semibold tracking-normal text-white">Matched remote jobs</h1>
        </div>
        <div class="flex items-center gap-3">
          <span class="max-w-[220px] truncate text-sm text-slate-400">{user.email}</span>
          <form method="POST" action="/api/auth/signout">
            <button
              type="submit"
              class="h-9 rounded-md border border-slate-700 px-3 text-sm font-medium text-slate-200 hover:border-slate-500 hover:bg-slate-900"
            >
              Sign out
            </button>
          </form>
        </div>
      </div>
    </header>

    <div class="mx-auto grid max-w-7xl gap-6 px-4 py-6 sm:px-6 lg:grid-cols-[360px_1fr]">
      <aside class="space-y-4">
        {
          saved === "preferences" && (
            <div class="rounded-md border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-100">
              Preferences saved.
            </div>
          )
        }
        {
          saved === "job" && (
            <div class="rounded-md border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-100">
              Job status saved.
            </div>
          )
        }
        {
          saved === "cv" && (
            <div class="rounded-md border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-100">
              CV profile extracted.
            </div>
          )
        }
        {
          pageError && (
            <div class="rounded-md border border-amber-500/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-100">
              {pageError}
            </div>
          )
        }
        {
          jobsMessage && (
            <div class="rounded-md border border-amber-500/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-100">
              {jobsMessage}
            </div>
          )
        }
        {
          jobSourceWarnings.map((warning) => (
            <div class="rounded-md border border-amber-500/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-100">
              <span class="font-medium">{warning.source}:</span> {warning.message}
            </div>
          ))
        }

        <section id="cv-upload" class="rounded-md border border-slate-800 bg-slate-900 p-4">
          <div class="mb-4 flex items-center justify-between gap-3">
            <h2 class="text-base font-semibold text-white">CV profile</h2>
            <span class="rounded-md bg-slate-800 px-2 py-1 text-xs text-slate-300">
              {cvProfile ? "Extracted" : "Empty"}
            </span>
          </div>

          <form method="POST" action="/api/cv/upload" enctype="multipart/form-data" class="space-y-3">
            <label class="block">
              <span class="mb-1 block text-sm font-medium text-slate-300">PDF CV</span>
              <input
                name="cv"
                type="file"
                accept="application/pdf,.pdf"
                class="block w-full rounded-md border border-slate-700 bg-slate-950 px-3 py-2 text-sm text-slate-200 file:mr-3 file:rounded-md file:border-0 file:bg-slate-800 file:px-3 file:py-1.5 file:text-sm file:font-medium file:text-slate-100 hover:file:bg-slate-700"
              />
            </label>
            <button
              type="submit"
              class="h-10 w-full rounded-md bg-cyan-400 px-4 text-sm font-semibold text-slate-950 hover:bg-cyan-300"
            >
              Upload and extract
            </button>
          </form>

          {
            cvProfile ? (
              <div class="mt-4 space-y-3 border-t border-slate-800 pt-4">
                <div>
                  <p class="text-sm font-medium text-white">{cvProfile.full_name ?? "Name not detected"}</p>
                  <p class="mt-1 text-xs text-slate-400">
                    {cvProfile.file_name} / {formatBytes(cvProfile.file_size)}
                  </p>
                </div>
                {(cvProfile.email ?? cvProfile.phone) && (
                  <p class="text-xs text-slate-400">{[cvProfile.email, cvProfile.phone].filter(Boolean).join(" / ")}</p>
                )}
                {cvProfile.role_hints.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {cvProfile.role_hints.slice(0, 3).map((role) => (
                      <span class="rounded-md bg-cyan-400/10 px-2 py-1 text-xs font-medium text-cyan-200">{role}</span>
                    ))}
                  </div>
                )}
                {cvProfile.skills.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {cvProfile.skills.slice(0, 10).map((skill) => (
                      <span class="rounded-md border border-slate-700 px-2 py-1 text-xs text-slate-300">{skill}</span>
                    ))}
                  </div>
                )}
                {cvProfile.experience_highlights.length > 0 && (
                  <ul class="space-y-2 text-xs text-slate-400">
                    {cvProfile.experience_highlights.slice(0, 2).map((highlight) => (
                      <li>{highlight}</li>
                    ))}
                  </ul>
                )}
              </div>
            ) : (
              <p class="mt-4 border-t border-slate-800 pt-4 text-sm text-slate-400">
                Upload a text-based PDF CV to unlock CV-based matching in the next slice.
              </p>
            )
          }
        </section>

        <section class="rounded-md border border-slate-800 bg-slate-900 p-4">
          <div class="mb-4 flex items-center justify-between gap-3">
            <h2 class="text-base font-semibold text-white">Preferences</h2>
            <span class="rounded-md bg-slate-800 px-2 py-1 text-xs text-slate-300">
              {hasPreferences ? "Active" : "Empty"}
            </span>
          </div>

          <form method="POST" action="/api/preferences" class="space-y-4">
            <label class="block">
              <span class="mb-1 block text-sm font-medium text-slate-300">Target roles</span>
              <input
                name="target_roles"
                value={joinList(preferences?.target_roles)}
                placeholder="Senior Fullstack, Python, Frontend"
                class="h-10 w-full rounded-md border border-slate-700 bg-slate-950 px-3 text-sm text-white outline-none focus:border-cyan-400"
              />
            </label>

            <label class="block">
              <span class="mb-1 block text-sm font-medium text-slate-300">Technologies</span>
              <input
                name="technologies"
                value={joinList(preferences?.technologies)}
                placeholder="TypeScript, React, Python, PostgreSQL"
                class="h-10 w-full rounded-md border border-slate-700 bg-slate-950 px-3 text-sm text-white outline-none focus:border-cyan-400"
              />
            </label>

            <div class="grid gap-3 sm:grid-cols-[1fr_168px]">
              <label class="block">
                <span class="mb-1 block text-sm font-medium text-slate-300">Min salary</span>
                <input
                  name="min_salary_amount"
                  type="number"
                  min="0"
                  value={preferences?.min_salary_amount ?? ""}
                  placeholder="8000"
                  class="h-10 w-full rounded-md border border-slate-700 bg-slate-950 px-3 text-sm text-white outline-none focus:border-cyan-400"
                />
              </label>
              <fieldset>
                <legend class="mb-1 block text-sm font-medium text-slate-300">Currency</legend>
                <div class="grid grid-cols-3 gap-2">
                  {
                    currencyOptions.map((currency) => (
                      <label class="relative flex h-10 min-w-0 items-center justify-center rounded-md border border-slate-700 bg-slate-950 text-sm font-medium text-slate-200 has-checked:border-cyan-400 has-checked:bg-cyan-400 has-checked:text-slate-950">
                        <input
                          type="radio"
                          name="salary_currency"
                          value={currency}
                          checked={(preferences?.salary_currency ?? "EUR") === currency}
                          class="sr-only"
                        />
                        <span>{currency}</span>
                      </label>
                    ))
                  }
                </div>
              </fieldset>
            </div>

            <div
              class="flex items-start gap-3 rounded-md border border-slate-700 bg-slate-950 p-3 text-sm text-slate-200"
            >
              <input
                id="include_unknown_salary"
                type="checkbox"
                name="include_unknown_salary"
                checked={preferences?.include_unknown_salary ?? true}
                class="mt-0.5 size-4 shrink-0 accent-cyan-400"
              />
              <span>
                <label for="include_unknown_salary" class="block font-medium text-slate-100">
                  Show jobs without salary when filtering by pay
                </label>
                <span class="mt-1 block text-xs text-slate-400">
                  Turn this off to require a listed salary that meets your minimum after MVP currency conversion.
                </span>
              </span>
            </div>

            <fieldset>
              <legend class="mb-2 text-sm font-medium text-slate-300">Work mode</legend>
              <div class="grid grid-cols-3 gap-2">
                {
                  [
                    ["remote", "Remote"],
                    ["hybrid", "Hybrid"],
                    ["onsite", "Onsite"],
                  ].map(([value, label]) => (
                    <label class="flex h-10 items-center justify-center gap-2 rounded-md border border-slate-700 bg-slate-950 text-sm text-slate-200">
                      <input
                        type="checkbox"
                        name="work_modes"
                        value={value}
                        checked={preferences?.work_modes.includes(value) ?? value === "remote"}
                        class="size-4 accent-cyan-400"
                      />
                      {label}
                    </label>
                  ))
                }
              </div>
            </fieldset>

            <label class="block">
              <span class="mb-1 block text-sm font-medium text-slate-300">Locations</span>
              <input
                name="locations"
                value={preferences?.locations ?? ""}
                placeholder="EU, US time zones, Poland"
                class="h-10 w-full rounded-md border border-slate-700 bg-slate-950 px-3 text-sm text-white outline-none focus:border-cyan-400"
              />
            </label>

            <button
              type="submit"
              class="h-10 w-full rounded-md bg-cyan-400 px-4 text-sm font-semibold text-slate-950 hover:bg-cyan-300"
            >
              Save preferences
            </button>
          </form>
        </section>
      </aside>

      <section class="space-y-4">
        <div class="grid gap-3 sm:grid-cols-3">
          <div class="rounded-md border border-slate-800 bg-slate-900 p-4">
            <p class="text-sm text-slate-400">Visible jobs</p>
            <p class="mt-1 text-2xl font-semibold text-white">{jobs.length}</p>
          </div>
          <div class="rounded-md border border-slate-800 bg-slate-900 p-4">
            <p class="text-sm text-slate-400">Saved jobs</p>
            <p class="mt-1 text-2xl font-semibold text-white">{savedJobs.size}</p>
          </div>
          <div class="rounded-md border border-slate-800 bg-slate-900 p-4">
            <p class="text-sm text-slate-400">Sources</p>
            <p class="mt-1 text-2xl font-semibold text-white">
              {jobsSource === "fallback" ? "Demo" : successfulSources}
            </p>
          </div>
        </div>

        <div
          id="scoring-error-banner"
          hidden
          class="rounded-md border border-rose-500/30 bg-rose-900/30 px-4 py-3 text-sm text-rose-300"
        >
          Job scoring is currently unavailable — try refreshing the page.
        </div>

        {
          jobs.length === 0 ? (
            <div class="rounded-md border border-slate-800 bg-slate-900 p-8 text-center">
              <h2 class="text-lg font-semibold text-white">No matching jobs</h2>
              <p class="mt-2 text-sm text-slate-400">Adjust role, salary, or work mode preferences.</p>
            </div>
          ) : (
            <div class="space-y-3">
              {jobs.map((job) => {
                const savedJob = savedJobs.get(job.id);

                return (
                  <article class="rounded-md border border-slate-800 bg-slate-900 p-4">
                    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                      <div class="min-w-0">
                        <div class="mb-2 flex flex-wrap items-center gap-2">
                          <span class="rounded-md bg-slate-800 px-2 py-1 text-xs font-medium text-slate-300">
                            {job.source}
                          </span>
                          {jobsSource === "fallback" ? (
                            <span class="rounded-md bg-cyan-400/10 px-2 py-1 text-xs font-medium text-cyan-200">
                              {job.matchScore}% match
                            </span>
                          ) : !cvProfile ? (
                            <a
                              href="/dashboard#cv-upload"
                              class="rounded-md bg-slate-700 px-2 py-1 text-xs text-slate-400 hover:text-slate-300"
                            >
                              Upload CV to see match
                            </a>
                          ) : cachedScores.has(job.id) ? (
                            <span
                              class="score-badge rounded-md bg-cyan-400/10 px-2 py-1 text-xs font-medium text-cyan-200"
                              data-job-id={job.id}
                            >
                              {cachedScores.get(job.id)?.score}% match
                            </span>
                          ) : (
                            <span
                              class="score-badge animate-pulse rounded-md bg-slate-700/50 px-2 py-1 text-xs font-medium text-slate-500"
                              data-job-id={job.id}
                              data-score-pending="true"
                              data-job-payload={JSON.stringify({
                                id: job.id,
                                source: job.source,
                                title: job.title,
                                company: job.company,
                                description: job.description ?? null,
                                technologies: job.technologies,
                              })}
                            >
                              Scoring…
                            </span>
                          )}
                          {savedJob && (
                            <span class="rounded-md bg-emerald-400/10 px-2 py-1 text-xs font-medium text-emerald-200">
                              {statusLabels[savedJob.status]}
                            </span>
                          )}
                        </div>
                        <h2 class="text-lg font-semibold text-white">
                          <a
                            href={job.url}
                            class="hover:text-cyan-200 hover:underline"
                            rel="noreferrer"
                            target="_blank"
                          >
                            {job.title}
                          </a>
                        </h2>
                        <p class="mt-1 text-sm text-slate-400">
                          {job.company} / {job.location} /{" "}
                          {job.salaryMin === null
                            ? "Salary not listed"
                            : `${job.salaryMin.toLocaleString()} ${job.salaryCurrency}`}
                        </p>
                        {job.matchReason && <p class="mt-3 text-sm text-slate-300">{job.matchReason}</p>}
                        <div class="mt-3 flex flex-wrap gap-2">
                          {job.technologies.map((tech) => (
                            <span class="rounded-md border border-slate-700 px-2 py-1 text-xs text-slate-300">
                              {tech}
                            </span>
                          ))}
                        </div>
                        {job.missingSkills.length > 0 && (
                          <p class="mt-3 text-xs text-slate-500">Missing: {job.missingSkills.slice(0, 4).join(", ")}</p>
                        )}
                        {jobsSource !== "fallback" && cvProfile && (
                          <>
                            <div id={"detail-" + job.id} hidden class="mt-3 space-y-2 border-t border-slate-800 pt-3">
                              {cachedScores.has(job.id) ? (
                                <>
                                  <p class="text-xs text-slate-400" data-detail-explanation={job.id}>
                                    {cachedScores.get(job.id)?.explanation}
                                  </p>
                                  {(cachedScores.get(job.id)?.matched_skills.length ?? 0) > 0 && (
                                    <div>
                                      <p class="text-xs font-medium text-emerald-400">Matched</p>
                                      <div class="mt-1 flex flex-wrap gap-1">
                                        {cachedScores.get(job.id)?.matched_skills.map((s) => (
                                          <span class="rounded bg-emerald-400/10 px-1.5 py-0.5 text-xs text-emerald-300">
                                            {s}
                                          </span>
                                        ))}
                                      </div>
                                    </div>
                                  )}
                                  {(cachedScores.get(job.id)?.missing_skills.length ?? 0) > 0 && (
                                    <div>
                                      <p class="text-xs font-medium text-rose-400">Missing</p>
                                      <div class="mt-1 flex flex-wrap gap-1">
                                        {cachedScores.get(job.id)?.missing_skills.map((s) => (
                                          <span class="rounded bg-rose-400/10 px-1.5 py-0.5 text-xs text-rose-300">
                                            {s}
                                          </span>
                                        ))}
                                      </div>
                                    </div>
                                  )}
                                </>
                              ) : (
                                <>
                                  <p
                                    class="text-xs text-slate-500 italic"
                                    data-detail-explanation={job.id}
                                    data-detail-pending="true"
                                  >
                                    Scoring…
                                  </p>
                                  <div data-detail-skills={job.id} data-detail-pending="true" />
                                </>
                              )}
                            </div>
                            <div
                              id={"cover-letter-" + job.id}
                              hidden
                              class="mt-3 rounded-md border border-slate-700 bg-slate-900 p-4 text-sm text-slate-300"
                            >
                              <div data-cover-letter-loading={job.id} hidden>
                                <span class="animate-pulse text-slate-400">Generating cover letter…</span>
                              </div>
                              <div data-cover-letter-content={job.id} hidden>
                                <pre
                                  class="font-sans leading-relaxed whitespace-pre-wrap"
                                  data-cover-letter-text={job.id}
                                />
                                <button
                                  type="button"
                                  data-cover-letter-copy={job.id}
                                  class="mt-3 rounded border border-slate-600 px-3 py-1 text-xs text-slate-400 hover:border-cyan-400 hover:text-cyan-200"
                                >
                                  Copy
                                </button>
                              </div>
                              <div data-cover-letter-error={job.id} hidden class="text-rose-400">
                                Failed to generate. Try again.
                              </div>
                            </div>
                          </>
                        )}
                      </div>

                      <form method="POST" action="/api/saved-jobs" class="w-full shrink-0 space-y-2 lg:w-56">
                        <input type="hidden" name="external_id" value={job.id} />
                        <input type="hidden" name="source" value={job.source} />
                        <input type="hidden" name="title" value={job.title} />
                        <input type="hidden" name="company" value={job.company} />
                        <input type="hidden" name="url" value={job.url} />
                        <fieldset>
                          <legend class="mb-2 text-xs font-medium text-slate-400">Status</legend>
                          <div class="grid grid-cols-3 gap-2 lg:grid-cols-1">
                            {Object.entries(statusLabels).map(([value, label]) => {
                              const activeStatus = savedJob?.status ?? "interested";
                              const isActive = activeStatus === value;

                              return (
                                <button
                                  type="submit"
                                  name="status"
                                  value={value}
                                  class:list={[
                                    "h-10 min-w-0 rounded-md border px-2 text-xs font-semibold sm:text-sm",
                                    isActive
                                      ? "border-cyan-400 bg-cyan-400 text-slate-950"
                                      : "border-slate-700 text-slate-200 hover:border-cyan-400 hover:text-cyan-200",
                                  ]}
                                >
                                  {label}
                                </button>
                              );
                            })}
                          </div>
                        </fieldset>
                        {jobsSource !== "fallback" && cvProfile && (
                          <div>
                            <p class="mb-2 text-xs font-medium text-slate-400">Actions</p>
                            <div class="grid grid-cols-3 gap-2 lg:grid-cols-1">
                              <button
                                type="button"
                                data-detail-toggle={job.id}
                                class="h-10 min-w-0 rounded-md border border-slate-700 px-2 text-xs font-semibold text-slate-200 hover:border-cyan-400 hover:text-cyan-200 sm:text-sm"
                              >
                                Details
                              </button>
                              <button
                                type="button"
                                data-cover-letter-toggle={job.id}
                                data-cover-letter-payload={JSON.stringify({
                                  id: job.id,
                                  source: job.source,
                                  title: job.title,
                                  company: job.company,
                                  description: job.description ?? null,
                                  technologies: job.technologies,
                                })}
                                class="h-10 min-w-0 rounded-md border border-slate-700 px-2 text-xs font-semibold text-slate-200 hover:border-cyan-400 hover:text-cyan-200 sm:text-sm"
                              >
                                Cover letter
                              </button>
                            </div>
                          </div>
                        )}
                      </form>
                    </div>
                  </article>
                );
              })}
            </div>
          )
        }
      </section>
    </div>
  </main>
  <script>
    function escHtml(s: string) {
      return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
    }

    document.addEventListener("click", (e) => {
      const btn = (e.target as HTMLElement).closest("[data-detail-toggle]") as HTMLElement | null;
      if (btn) {
        const panel = document.getElementById("detail-" + btn.dataset.detailToggle);
        panel?.toggleAttribute("hidden");
      }
    });

    type ScoreEntry = {
      score: number;
      explanation: string;
      matched_skills: string[];
      missing_skills: string[];
    };

    function applyScores(scores: Record<string, ScoreEntry | null>) {
      for (const [jobId, score] of Object.entries(scores)) {
        const badge = document.querySelector<HTMLElement>(`[data-job-id="${CSS.escape(jobId)}"][data-score-pending]`);
        if (!score) {
          if (badge) {
            badge.textContent = "—";
            badge.classList.remove("animate-pulse");
            badge.removeAttribute("data-score-pending");
          }
          continue;
        }
        if (badge) {
          badge.textContent = score.score + "% match";
          badge.classList.remove("animate-pulse", "bg-slate-700/50", "text-slate-500");
          badge.classList.add("bg-cyan-400/10", "text-cyan-200");
          badge.removeAttribute("data-score-pending");
        }
        const expEl = document.querySelector<HTMLElement>(`[data-detail-explanation="${CSS.escape(jobId)}"]`);
        if (expEl) {
          expEl.textContent = score.explanation;
          expEl.removeAttribute("data-detail-pending");
        }
        const skillsEl = document.querySelector<HTMLElement>(`[data-detail-skills="${CSS.escape(jobId)}"]`);
        if (skillsEl) {
          let html = "";
          if (score.matched_skills?.length) {
            html +=
              '<div><p class="text-xs font-medium text-emerald-400">Matched</p><div class="mt-1 flex flex-wrap gap-1">';
            for (const s of score.matched_skills)
              html += `<span class="rounded bg-emerald-400/10 px-1.5 py-0.5 text-xs text-emerald-300">${escHtml(s)}</span>`;
            html += "</div></div>";
          }
          if (score.missing_skills?.length) {
            html +=
              '<div class="mt-1"><p class="text-xs font-medium text-rose-400">Missing</p><div class="mt-1 flex flex-wrap gap-1">';
            for (const s of score.missing_skills)
              html += `<span class="rounded bg-rose-400/10 px-1.5 py-0.5 text-xs text-rose-300">${escHtml(s)}</span>`;
            html += "</div></div>";
          }
          skillsEl.innerHTML = html;
          skillsEl.removeAttribute("data-detail-pending");
        }
      }
    }

    async function fireBatch(attempt: number): Promise<void> {
      const pending = [...document.querySelectorAll<HTMLElement>("[data-score-pending='true']")];
      if (pending.length === 0) return;
      if (attempt > 6) {
        document.getElementById("scoring-error-banner")?.removeAttribute("hidden");
        pending.forEach((el) => {
          el.textContent = "—";
          el.classList.remove("animate-pulse");
        });
        return;
      }
      const jobs = pending
        .map((el) => {
          try {
            return JSON.parse(el.dataset.jobPayload ?? "") as unknown;
          } catch {
            return null;
          }
        })
        .filter(Boolean);
      const errorBanner = document.getElementById("scoring-error-banner");
      errorBanner?.setAttribute("hidden", "");
      try {
        const res = await fetch("/api/jobs/score-batch", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ jobs }),
        });
        if (!res.ok) {
          errorBanner?.removeAttribute("hidden");
          document.querySelectorAll<HTMLElement>("[data-score-pending='true']").forEach((el) => {
            el.textContent = "—";
            el.classList.remove("animate-pulse");
          });
          return;
        }
        const data = (await res.json()) as { scores?: Record<string, ScoreEntry | null>; noCV?: boolean };
        if (data.noCV) return;
        applyScores(data.scores ?? {});
        const stillPending = document.querySelectorAll("[data-score-pending='true']").length;
        if (stillPending > 0) setTimeout(() => void fireBatch(attempt + 1), 2000);
      } catch {
        errorBanner?.removeAttribute("hidden");
        document.querySelectorAll<HTMLElement>("[data-score-pending='true']").forEach((el) => {
          el.textContent = "—";
          el.classList.remove("animate-pulse");
        });
      }
    }

    if (document.querySelector("[data-score-pending='true']")) void fireBatch(0);
  </script>
  <script>
    document.addEventListener("click", (e) => {
      const toggleBtn = (e.target as HTMLElement).closest("[data-cover-letter-toggle]") as HTMLElement | null;
      if (toggleBtn) {
        const id = toggleBtn.dataset.coverLetterToggle!;
        const panel = document.getElementById("cover-letter-" + id);
        if (!panel) return;
        panel.toggleAttribute("hidden");
        const contentDiv = document.querySelector<HTMLElement>(`[data-cover-letter-content="${CSS.escape(id)}"]`);
        if (!panel.hasAttribute("hidden") && contentDiv?.hasAttribute("hidden")) {
          void fetchCoverLetter(id);
        }
        return;
      }

      const copyBtn = (e.target as HTMLElement).closest("[data-cover-letter-copy]") as HTMLElement | null;
      if (copyBtn) {
        const id = copyBtn.dataset.coverLetterCopy!;
        const pre = document.querySelector<HTMLElement>(`[data-cover-letter-text="${CSS.escape(id)}"]`);
        if (pre?.textContent) {
          void navigator.clipboard.writeText(pre.textContent).then(() => {
            copyBtn.textContent = "Copied!";
            setTimeout(() => {
              copyBtn.textContent = "Copy";
            }, 2000);
          });
        }
      }
    });

    async function fetchCoverLetter(id: string): Promise<void> {
      const loadingDiv = document.querySelector<HTMLElement>(`[data-cover-letter-loading="${CSS.escape(id)}"]`);
      const contentDiv = document.querySelector<HTMLElement>(`[data-cover-letter-content="${CSS.escape(id)}"]`);
      const errorDiv = document.querySelector<HTMLElement>(`[data-cover-letter-error="${CSS.escape(id)}"]`);
      const pre = document.querySelector<HTMLElement>(`[data-cover-letter-text="${CSS.escape(id)}"]`);
      const btn = document.querySelector<HTMLElement>(`[data-cover-letter-toggle="${CSS.escape(id)}"]`);
      if (!btn) return;

      errorDiv?.setAttribute("hidden", "");
      loadingDiv?.removeAttribute("hidden");

      try {
        const job = JSON.parse(btn.dataset.coverLetterPayload ?? "{}") as unknown;
        const res = await fetch("/api/jobs/cover-letter", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ job }),
        });
        const data = (await res.json()) as { content?: string; error?: string; noCV?: boolean };
        if (!res.ok || data.error) throw new Error(data.error ?? "Request failed");
        if (data.noCV) throw new Error("No CV");
        if (pre) pre.textContent = data.content ?? "";
        contentDiv?.removeAttribute("hidden");
      } catch {
        errorDiv?.removeAttribute("hidden");
      } finally {
        loadingDiv?.setAttribute("hidden", "");
      }
    }
  </script>
</Layout>
