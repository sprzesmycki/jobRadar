---
import Layout from "@/layouts/Layout.astro";
import { getMatchedJobs } from "@/lib/jobs";
import { getJobPreferences, joinList } from "@/lib/preferences";
import { getSavedJobs } from "@/lib/saved-jobs";
import { createClient } from "@/lib/supabase";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);

if (!user || !supabase) {
  throw new Error("Dashboard requires an authenticated Supabase session.");
}

const saved = Astro.url.searchParams.get("saved");
const routeError = Astro.url.searchParams.get("error");
const { preferences, errorMessage: preferencesError } = await getJobPreferences(supabase, user.id);
const { savedJobs, errorMessage: savedJobsError } = await getSavedJobs(supabase, user.id);
const pageError = routeError ?? preferencesError ?? savedJobsError;
const { jobs, message: jobsMessage, source: jobsSource } = await getMatchedJobs(preferences);
const hasPreferences = Boolean(preferences);
const statusLabels = {
  interested: "Interested",
  applied: "Applied",
  rejected: "Rejected",
};
const currencyOptions = ["EUR", "USD", "PLN"];
---

<Layout title="JobRadar Dashboard">
  <main class="min-h-screen bg-slate-950 text-slate-100">
    <header class="border-b border-slate-800 bg-slate-950/95">
      <div
        class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-5 sm:flex-row sm:items-center sm:justify-between sm:px-6"
      >
        <div>
          <p class="text-sm font-medium text-cyan-300">JobRadar</p>
          <h1 class="text-2xl font-semibold tracking-normal text-white">Matched remote jobs</h1>
        </div>
        <div class="flex items-center gap-3">
          <span class="max-w-[220px] truncate text-sm text-slate-400">{user.email}</span>
          <form method="POST" action="/api/auth/signout">
            <button
              type="submit"
              class="h-9 rounded-md border border-slate-700 px-3 text-sm font-medium text-slate-200 hover:border-slate-500 hover:bg-slate-900"
            >
              Sign out
            </button>
          </form>
        </div>
      </div>
    </header>

    <div class="mx-auto grid max-w-7xl gap-6 px-4 py-6 sm:px-6 lg:grid-cols-[360px_1fr]">
      <aside class="space-y-4">
        {
          saved === "preferences" && (
            <div class="rounded-md border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-100">
              Preferences saved.
            </div>
          )
        }
        {
          saved === "job" && (
            <div class="rounded-md border border-emerald-500/30 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-100">
              Job status saved.
            </div>
          )
        }
        {
          pageError && (
            <div class="rounded-md border border-amber-500/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-100">
              {pageError}
            </div>
          )
        }
        {
          jobsMessage && (
            <div class="rounded-md border border-amber-500/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-100">
              {jobsMessage}
            </div>
          )
        }

        <section class="rounded-md border border-slate-800 bg-slate-900 p-4">
          <div class="mb-4 flex items-center justify-between gap-3">
            <h2 class="text-base font-semibold text-white">Preferences</h2>
            <span class="rounded-md bg-slate-800 px-2 py-1 text-xs text-slate-300">
              {hasPreferences ? "Active" : "Empty"}
            </span>
          </div>

          <form method="POST" action="/api/preferences" class="space-y-4">
            <label class="block">
              <span class="mb-1 block text-sm font-medium text-slate-300">Target roles</span>
              <input
                name="target_roles"
                value={joinList(preferences?.target_roles)}
                placeholder="Senior Fullstack, Python, Frontend"
                class="h-10 w-full rounded-md border border-slate-700 bg-slate-950 px-3 text-sm text-white outline-none focus:border-cyan-400"
              />
            </label>

            <label class="block">
              <span class="mb-1 block text-sm font-medium text-slate-300">Technologies</span>
              <input
                name="technologies"
                value={joinList(preferences?.technologies)}
                placeholder="TypeScript, React, Python, PostgreSQL"
                class="h-10 w-full rounded-md border border-slate-700 bg-slate-950 px-3 text-sm text-white outline-none focus:border-cyan-400"
              />
            </label>

            <div class="grid gap-3 sm:grid-cols-[1fr_168px]">
              <label class="block">
                <span class="mb-1 block text-sm font-medium text-slate-300">Min salary</span>
                <input
                  name="min_salary_amount"
                  type="number"
                  min="0"
                  value={preferences?.min_salary_amount ?? ""}
                  placeholder="8000"
                  class="h-10 w-full rounded-md border border-slate-700 bg-slate-950 px-3 text-sm text-white outline-none focus:border-cyan-400"
                />
              </label>
              <fieldset>
                <legend class="mb-1 block text-sm font-medium text-slate-300">Currency</legend>
                <div class="grid grid-cols-3 gap-2">
                  {
                    currencyOptions.map((currency) => (
                      <label class="relative flex h-10 min-w-0 items-center justify-center rounded-md border border-slate-700 bg-slate-950 text-sm font-medium text-slate-200 has-checked:border-cyan-400 has-checked:bg-cyan-400 has-checked:text-slate-950">
                        <input
                          type="radio"
                          name="salary_currency"
                          value={currency}
                          checked={(preferences?.salary_currency ?? "EUR") === currency}
                          class="sr-only"
                        />
                        <span>{currency}</span>
                      </label>
                    ))
                  }
                </div>
              </fieldset>
            </div>

            <div
              class="flex items-start gap-3 rounded-md border border-slate-700 bg-slate-950 p-3 text-sm text-slate-200"
            >
              <input
                id="include_unknown_salary"
                type="checkbox"
                name="include_unknown_salary"
                checked={preferences?.include_unknown_salary ?? true}
                class="mt-0.5 size-4 shrink-0 accent-cyan-400"
              />
              <span>
                <label for="include_unknown_salary" class="block font-medium text-slate-100">
                  Include jobs without listed salary
                </label>
                <span class="mt-1 block text-xs text-slate-400">
                  When unchecked, min salary filters out offers where Remotive does not provide a parseable salary.
                </span>
              </span>
            </div>

            <fieldset>
              <legend class="mb-2 text-sm font-medium text-slate-300">Work mode</legend>
              <div class="grid grid-cols-3 gap-2">
                {
                  [
                    ["remote", "Remote"],
                    ["hybrid", "Hybrid"],
                    ["onsite", "Onsite"],
                  ].map(([value, label]) => (
                    <label class="flex h-10 items-center justify-center gap-2 rounded-md border border-slate-700 bg-slate-950 text-sm text-slate-200">
                      <input
                        type="checkbox"
                        name="work_modes"
                        value={value}
                        checked={preferences?.work_modes.includes(value) ?? value === "remote"}
                        class="size-4 accent-cyan-400"
                      />
                      {label}
                    </label>
                  ))
                }
              </div>
            </fieldset>

            <label class="block">
              <span class="mb-1 block text-sm font-medium text-slate-300">Locations</span>
              <input
                name="locations"
                value={preferences?.locations ?? ""}
                placeholder="EU, US time zones, Poland"
                class="h-10 w-full rounded-md border border-slate-700 bg-slate-950 px-3 text-sm text-white outline-none focus:border-cyan-400"
              />
            </label>

            <button
              type="submit"
              class="h-10 w-full rounded-md bg-cyan-400 px-4 text-sm font-semibold text-slate-950 hover:bg-cyan-300"
            >
              Save preferences
            </button>
          </form>
        </section>
      </aside>

      <section class="space-y-4">
        <div class="grid gap-3 sm:grid-cols-3">
          <div class="rounded-md border border-slate-800 bg-slate-900 p-4">
            <p class="text-sm text-slate-400">Visible jobs</p>
            <p class="mt-1 text-2xl font-semibold text-white">{jobs.length}</p>
          </div>
          <div class="rounded-md border border-slate-800 bg-slate-900 p-4">
            <p class="text-sm text-slate-400">Saved jobs</p>
            <p class="mt-1 text-2xl font-semibold text-white">{savedJobs.size}</p>
          </div>
          <div class="rounded-md border border-slate-800 bg-slate-900 p-4">
            <p class="text-sm text-slate-400">Sources</p>
            <p class="mt-1 text-2xl font-semibold text-white">{jobsSource === "fallback" ? "Demo" : "1"}</p>
          </div>
        </div>

        {
          jobs.length === 0 ? (
            <div class="rounded-md border border-slate-800 bg-slate-900 p-8 text-center">
              <h2 class="text-lg font-semibold text-white">No matching jobs</h2>
              <p class="mt-2 text-sm text-slate-400">Adjust role, salary, or work mode preferences.</p>
            </div>
          ) : (
            <div class="space-y-3">
              {jobs.map((job) => {
                const savedJob = savedJobs.get(job.id);

                return (
                  <article class="rounded-md border border-slate-800 bg-slate-900 p-4">
                    <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                      <div class="min-w-0">
                        <div class="mb-2 flex flex-wrap items-center gap-2">
                          <span class="rounded-md bg-slate-800 px-2 py-1 text-xs font-medium text-slate-300">
                            {job.source}
                          </span>
                          <span class="rounded-md bg-cyan-400/10 px-2 py-1 text-xs font-medium text-cyan-200">
                            {job.matchScore}% match
                          </span>
                          {savedJob && (
                            <span class="rounded-md bg-emerald-400/10 px-2 py-1 text-xs font-medium text-emerald-200">
                              {statusLabels[savedJob.status]}
                            </span>
                          )}
                        </div>
                        <h2 class="text-lg font-semibold text-white">
                          <a
                            href={job.url}
                            class="hover:text-cyan-200 hover:underline"
                            rel="noreferrer"
                            target="_blank"
                          >
                            {job.title}
                          </a>
                        </h2>
                        <p class="mt-1 text-sm text-slate-400">
                          {job.company} / {job.location} /{" "}
                          {job.salaryMin === null
                            ? "Salary not listed"
                            : `${job.salaryMin.toLocaleString()} ${job.salaryCurrency}`}
                        </p>
                        <p class="mt-3 text-sm text-slate-300">{job.matchReason}</p>
                        <div class="mt-3 flex flex-wrap gap-2">
                          {job.technologies.map((tech) => (
                            <span class="rounded-md border border-slate-700 px-2 py-1 text-xs text-slate-300">
                              {tech}
                            </span>
                          ))}
                        </div>
                        {job.missingSkills.length > 0 && (
                          <p class="mt-3 text-xs text-slate-500">Missing: {job.missingSkills.slice(0, 4).join(", ")}</p>
                        )}
                      </div>

                      <form method="POST" action="/api/saved-jobs" class="w-full shrink-0 space-y-2 lg:w-56">
                        <input type="hidden" name="external_id" value={job.id} />
                        <input type="hidden" name="source" value={job.source} />
                        <input type="hidden" name="title" value={job.title} />
                        <input type="hidden" name="company" value={job.company} />
                        <input type="hidden" name="url" value={job.url} />
                        <fieldset>
                          <legend class="mb-2 text-xs font-medium text-slate-400">Status</legend>
                          <div class="grid grid-cols-3 gap-2 lg:grid-cols-1">
                            {Object.entries(statusLabels).map(([value, label]) => {
                              const activeStatus = savedJob?.status ?? "interested";
                              const isActive = activeStatus === value;

                              return (
                                <button
                                  type="submit"
                                  name="status"
                                  value={value}
                                  class:list={[
                                    "h-10 min-w-0 rounded-md border px-2 text-xs font-semibold sm:text-sm",
                                    isActive
                                      ? "border-cyan-400 bg-cyan-400 text-slate-950"
                                      : "border-slate-700 text-slate-200 hover:border-cyan-400 hover:text-cyan-200",
                                  ]}
                                >
                                  {label}
                                </button>
                              );
                            })}
                          </div>
                        </fieldset>
                      </form>
                    </div>
                  </article>
                );
              })}
            </div>
          )
        }
      </section>
    </div>
  </main>
</Layout>
